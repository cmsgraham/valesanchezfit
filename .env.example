# ===========================================
# VALESANCHEZ.FIT - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Database (PostgreSQL)
DATABASE_URI=postgresql://postgres:postgres@localhost:5432/valesanchez_fit

# Payload CMS
PAYLOAD_SECRET=your-super-secret-key-at-least-32-characters-long
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@valesanchez.fit
SMTP_FROM_NAME=Vale Sánchez Fitness
CONTACT_EMAIL=cristian.madrigal@gmail.com

# WhatsApp Configuration
NEXT_PUBLIC_WHATSAPP_NUMBER=50688546547
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hola! Me interesa saber más sobre los servicios de entrenamiento personal.

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=5

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: reCAPTCHA (for spam protection)
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Node Environment
NODE_ENV=development
