# ===========================================
# PRODUCTION ENVIRONMENT — copy to .env on the server
# ===========================================

# --- Database ---
DB_USER=postgres
DB_PASSWORD=change_me_strong_password
DB_NAME=valesanchez_fit

# Constructed automatically by docker-compose from the above — override only if
# you're connecting to an external PostgreSQL instance.
# DATABASE_URI=postgresql://postgres:change_me@db:5432/valesanchez_fit

# --- Payload CMS (REQUIRED) ---
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace_with_64_char_random_hex

# --- Site URL (REQUIRED) ---
NEXT_PUBLIC_SITE_URL=https://valesanchez.fit

# --- Email / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@valesanchez.fit
SMTP_FROM_NAME=Vale Sánchez Fitness
CONTACT_EMAIL=vale@valesanchez.fit

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=50688546547
NEXT_PUBLIC_WHATSAPP_MESSAGE=¡Hola! Me interesa saber más sobre los servicios de entrenamiento personal.
